# Godot caches and generated imports
.godot/
.import/
*.import

# Prevent accidental nested Godot projects from making imports ignore test folders
**/project.godot
!project.godot

# Godot temporary files
*.tmp
*.temp
*.translation

# .NET build output
bin/
obj/
[Bb]in/
[Oo]bj/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates


# Python caches
__pycache__/
*.pyc

# IDE caches
.vs/
.vscode/.ropeproject/
.vscode/.history/
.vscode/*.log
.idea/
*.code-workspace

# Local builds and exports
builds/
exports/
*.pck
*.zip
*.7z
*.tar
*.tar.gz

# Logs
*.log
logs/

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Secrets and environment files
.env
.env.*
*.secret
*.secrets

# Test outputs
tests/TestResults/
*.trx
*.coverage

# GdUnit4 generated runner
tests/gdunit4_testadapter_v5/

# Local rendered visual-review artifacts
artifacts/visual-review/

# Generated Phase 3A visual-review screenshots are distributed as workflow artifacts.
/docs/review/phase3a-pass1-terrain/*.png

# Generated temporary audio cues are materialized by tools/prepare_audio_assets.py in CI/local validation.
/assets/audio/temp/*.wav

# Blender Asset Forge outputs generally remain tracked when promoted by workflow.
# Stage A Terrain Diorama Kit binaries are generated local/CI artifacts only;
# text manifests and review docs are the tracked provenance/evidence surface.
artifacts/asset-review/TC_TerrainDioramaKit_V1/*.png
assets/Source/Blender/StageA/TC_TerrainDioramaKit_V1.blend
assets/Production/Generated/StageA/TC_TerrainDioramaKit_V1.glb
!artifacts/asset-review/.gitkeep
!artifacts/asset-review/**/.gitkeep
!assets/Source/Blender/.gitkeep
!assets/Source/Blender/**/.gitkeep
!assets/Production/Generated/.gitkeep
!assets/Production/Generated/**/.gitkeep
# Visual Artifact Factory generated review evidence
artifacts/asset-review/**/*.log
artifacts/visual-review/**/*.png
artifacts/visual-review/**/*.log
artifacts/visual-artifact-factory/**
