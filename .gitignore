# Godot caches and generated imports
.godot/
.import/
*.import

# Prevent accidental nested Godot projects from making imports ignore test folders
**/project.godot
!project.godot

# Godot temporary files
*.tmp
*.temp
*.translation

# .NET build output
bin/
obj/
[Bb]in/
[Oo]bj/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# IDE caches
.vs/
.vscode/.ropeproject/
.vscode/.history/
.vscode/*.log
.idea/
*.code-workspace

# Local builds and exports
builds/
exports/
*.pck
*.zip
*.7z
*.tar
*.tar.gz

# Logs
*.log
logs/

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Secrets and environment files
.env
.env.*
*.secret
*.secrets

# Test outputs
tests/TestResults/
*.trx
*.coverage

# GdUnit4 generated runner
tests/gdunit4_testadapter_v5/

# Local rendered visual-review artifacts
artifacts/visual-review/

# Generated Phase 3A visual-review screenshots are distributed as workflow artifacts.
/docs/review/phase3a-pass1-terrain/*.png

# Generated temporary audio cues are materialized by tools/prepare_audio_assets.py in CI/local validation.
/assets/audio/temp/*.wav

# Local Blender Asset Forge review renders
artifacts/asset-review/**/*.png
!artifacts/asset-review/.gitkeep
!artifacts/asset-review/**/.gitkeep
# Blender Asset Forge test-crate binaries are generated by GitHub Actions and downloaded as workflow artifacts.
# Real production .blend sources under assets/Source/Blender/ remain allowed for human-approved source assets.
assets/Source/Blender/_templates/**/*.blend
assets/Source/Blender/_templates/**/*.blend1
assets/Production/Generated/**/*.glb
assets/Production/Generated/asset_manifest.json
!assets/Source/Blender/.gitkeep
!assets/Source/Blender/**/.gitkeep
!assets/Production/Generated/.gitkeep
!assets/Production/Generated/**/.gitkeep
